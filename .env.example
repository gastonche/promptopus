# Promptopus — provider credentials.
# Copy to `.env` and fill in. NEVER commit your real .env (it is gitignored).
# Each provider reads its key from an env var; the var name is configurable per
# provider in the suite YAML (apiKeyEnv), but these are the defaults.

# OpenAI (kind: openai) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (kind: anthropic) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Workers AI, used via the OpenAI-compatible endpoint (kind: openai-compat).
# The suite references the base URL through an env var (baseUrlEnv: CF_AI_BASE_URL).
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-workers-ai-token
# OpenAI-compatible base URL. Either the AI Gateway compat endpoint (recommended, used by the
# benchmark) or the direct Workers AI endpoint:
#   CF_AI_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account-id>/<gateway>/compat
#   CF_AI_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<account-id>/ai/v1
CF_AI_BASE_URL=
# The openai-compat provider sends CLOUDFLARE_API_TOKEN as the bearer token when
# its apiKeyEnv points at it (apiKeyEnv: CLOUDFLARE_API_TOKEN).
