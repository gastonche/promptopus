{
  "name": "promptopus",
  "version": "0.1.1",
  "description": "A config-driven LLM evaluation harness — CLI + dashboard. Define an eval in YAML, run it against many models, score every output with deterministic, LLM-as-judge, and cost/latency graders, and compare side by side.",
  "type": "module",
  "license": "MIT",
  "author": "Gaston Che",
  "homepage": "https://promptopus.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gastonche/promptopus.git"
  },
  "bugs": {
    "url": "https://github.com/gastonche/promptopus/issues"
  },
  "keywords": [
    "llm",
    "evaluation",
    "eval",
    "openai",
    "anthropic",
    "prompt",
    "testing",
    "cli",
    "llm-as-judge",
    "benchmark",
    "ai"
  ],
  "bin": {
    "promptopus": "./dist/cli/index.js",
    "pop": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "examples",
    "dashboard",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc -p tsconfig.json --watch",
    "bundle:dashboard": "node scripts/bundle-dashboard.mjs",
    "prepack": "node scripts/bundle-dashboard.mjs",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
