{
  "name": "@promptopus/core",
  "version": "0.1.0",
  "description": "Promptopus core: domain model, config loader, providers, graders, runner, and CLI.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "promptopus": "./dist/cli/index.js",
    "pop": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
