{
  "name": "promptopus",
  "version": "0.1.0",
  "private": true,
  "description": "Promptopus — a config-driven LLM evaluation harness (CLI + dashboard).",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
