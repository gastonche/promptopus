    "dev": "turbo run dev",
    "promptopus": "node packages/core/dist/cli/index.js"
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2"
}
