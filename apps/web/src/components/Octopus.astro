---
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 128 128"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <defs>
    <radialGradient id="oh" cx="42%" cy="34%" r="72%">
      <stop offset="0%" stop-color="#C4B5FD"></stop>
      <stop offset="45%" stop-color="#A855F7"></stop>
      <stop offset="100%" stop-color="#6D28D9"></stop>
    </radialGradient>
    <linearGradient id="oa" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#7C3AED"></stop>
      <stop offset="100%" stop-color="#6D28D9"></stop>
    </linearGradient>
  </defs>
  <g stroke="url(#oa)" stroke-width="9" stroke-linecap="round" fill="none">
    <path d="M44 78 C 30 96, 24 104, 16 100"></path>
    <path d="M52 84 C 44 104, 40 116, 32 116"></path>
    <path d="M64 86 C 64 108, 64 118, 60 122"></path>
    <path d="M76 84 C 84 104, 88 116, 96 116"></path>
    <path d="M84 78 C 98 96, 104 104, 112 100"></path>
  </g>
  <path
    d="M64 18 C 88 18, 100 38, 100 60 C 100 78, 86 88, 64 88 C 42 88, 28 78, 28 60 C 28 38, 40 18, 64 18 Z"
    fill="url(#oh)"></path>
  <circle cx="51" cy="56" r="9" fill="#1E1B2E"></circle>
  <circle cx="77" cy="56" r="9" fill="#1E1B2E"></circle>
  <circle cx="54" cy="53" r="3" fill="#F5F3FF"></circle>
  <circle cx="80" cy="53" r="3" fill="#F5F3FF"></circle>
</svg>
