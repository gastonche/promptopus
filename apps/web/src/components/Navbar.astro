---
import Octopus from './Octopus.astro';
const { pathname } = Astro.url;
const onDocs = pathname.startsWith('/docs');
---

<header class="sticky top-0 z-40 border-b border-pop-300/40 bg-surface/80 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-3 px-5">
    <a href="/" class="flex items-center gap-2.5 font-bold tracking-tight">
      <Octopus size={32} />
      <span class="text-lg">
        <span class="text-pop-700">Prompt</span><span class="text-pop-500">opus</span>
      </span>
    </a>

    <nav class="ml-6 hidden items-center gap-1 text-sm font-medium md:flex">
      <a
        href="/docs/introduction"
        class={`rounded-lg px-3 py-1.5 transition hover:bg-pop-600/10 ${onDocs ? 'text-pop-700' : 'text-ink/70'}`}
        >Docs</a
      >
      <a href="/#features" class="rounded-lg px-3 py-1.5 text-ink/70 transition hover:bg-pop-600/10"
        >Features</a
      >
      <a href="/#dogfood" class="rounded-lg px-3 py-1.5 text-ink/70 transition hover:bg-pop-600/10"
        >Proof</a
      >
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a
        href="/docs/getting-started"
        class="hidden rounded-lg px-3 py-1.5 text-sm font-medium text-ink/70 transition hover:bg-pop-600/10 sm:block"
        >Quickstart</a
      >
      <a
        href="https://github.com/"
        class="flex items-center gap-2 rounded-lg bg-pop-700 px-3.5 py-1.5 text-sm font-semibold text-white transition hover:bg-pop-600"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 5 18.3 5.3 18.3 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
          ></path>
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
    </div>
  </div>
</header>
